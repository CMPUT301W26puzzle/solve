<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header Image + Back Arrow -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- White bar behind back arrow -->
            <View
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="#FFFFFF" />

            <!-- Event Poster -->
            <ImageView
                android:id="@+id/ivEventPoster"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:layout_marginTop="56dp"
                android:scaleType="centerCrop"
                android:background="#CCCCCC"
                android:contentDescription="Event poster" />

            <!-- Back Button -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="8dp"
                android:background="@null"
                android:src="@drawable/arrowlogo"
                android:contentDescription="Back" />

        </FrameLayout>

        <!-- Content below image -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Title + Price Badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tvEventName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:text="Event Name" />

                <TextView
                    android:id="@+id/tvEventPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp"
                    android:background="@drawable/badge_price_dark_bg"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:text="Free" />

            </LinearLayout>

            <!-- Category Chips -->
            <LinearLayout
                android:id="@+id/layoutTags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/tvTag1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:background="@drawable/tag_outline_bg"
                    android:textSize="13sp"
                    android:textColor="#333333"
                    android:layout_marginEnd="8dp"
                    android:visibility="gone"
                    android:text="Tag" />

                <TextView
                    android:id="@+id/tvTag2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:background="@drawable/tag_outline_bg"
                    android:textSize="13sp"
                    android:textColor="#333333"
                    android:layout_marginEnd="8dp"
                    android:visibility="gone"
                    android:text="Tag" />

                <TextView
                    android:id="@+id/tvTag3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:background="@drawable/tag_outline_bg"
                    android:textSize="13sp"
                    android:textColor="#333333"
                    android:visibility="gone"
                    android:text="Tag" />

            </LinearLayout>

            <!-- Info Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Date Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/clocklogo"
                            app:tint="#555555"
                            android:layout_marginEnd="12dp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvEventDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#000000"
                                android:text="Date" />

                            <TextView
                                android:id="@+id/tvEventTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="13sp"
                                android:textColor="#666666"
                                android:text="Time" />

                        </LinearLayout>
                    </LinearLayout>

                    <!-- Divider -->
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#EEEEEE" android:layout_marginBottom="16dp"/>

                    <!-- Location Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/pinlogo"
                            app:tint="#555555"
                            android:layout_marginEnd="12dp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvVenueName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#000000"
                                android:text="Venue" />

                            <TextView
                                android:id="@+id/tvVenueAddress"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="13sp"
                                android:textColor="#666666"
                                android:text="Address" />

                        </LinearLayout>
                    </LinearLayout>

                    <!-- Divider -->
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#EEEEEE" android:layout_marginBottom="16dp"/>

                    <!-- Capacity Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/entrantlogo"
                            app:tint="#555555"
                            android:layout_marginEnd="12dp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvCapacity"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#000000"
                                android:text="Capacity: 0" />

                            <!-- Enrolled + Waiting (US 01.05.04) -->
                            <TextView
                                android:id="@+id/tvEnrolledWaiting"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="13sp"
                                android:textColor="#666666"
                                android:text="0 enrolled • 0 waiting" />

                        </LinearLayout>
                    </LinearLayout>

                    <!-- Divider -->
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#EEEEEE" android:layout_marginBottom="16dp"/>

                    <!-- Registration Deadline Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/organizerlogo"
                            app:tint="#555555"
                            android:layout_marginEnd="12dp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#000000"
                                android:text="Registration Deadline" />

                            <TextView
                                android:id="@+id/tvRegistrationDeadline"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="13sp"
                                android:textColor="#666666"
                                android:text="N/A" />

                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- About Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="About this event"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvAbout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginBottom="24dp"
                android:text="N/A" />

            <!-- Join / Leave Waiting List Button (US 01.01.01 / 01.01.02) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnJoinLeave"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Join Waiting List"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#000000"
                app:cornerRadius="12dp"
                android:layout_marginBottom="24dp" />

        </LinearLayout>
    </LinearLayout>

</androidx.core.widget.NestedScrollView>
